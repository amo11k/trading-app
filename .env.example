# Finnhub API Key - Get yours free at https://finnhub.io/register
VITE_FINNHUB_API_KEY=your_api_key_here

# Enable mock data fallback when API rate limit is reached or API key is missing
# Set to 'true' to always use mock data, 'false' to use real API only
VITE_USE_MOCK_DATA=true

# Data refresh interval in seconds (default: 30)
VITE_REFRESH_INTERVAL=30
